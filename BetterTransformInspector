using UnityEngine;
using UnityEditor;

[CanEditMultipleObjects]
[CustomEditor(typeof(Transform), true)]
public class CustomTransformInspector : Editor
{
    SerializedProperty mPos;
    SerializedProperty mRot;
    SerializedProperty mScale;

    void OnEnable()
    {
        mPos = serializedObject.FindProperty("m_LocalPosition");
        mRot = serializedObject.FindProperty("m_LocalRotation");
        mScale = serializedObject.FindProperty("m_LocalScale");
    }

    public override void OnInspectorGUI()
    {
        serializedObject.Update();

        DrawPosition();
        DrawRotation();
        DrawScale();

        serializedObject.ApplyModifiedProperties();
    }

    void DrawPosition()
    {
        GUILayout.BeginHorizontal();
        if (GUILayout.Button("P", GUILayout.Width(20f)))
        {
            Undo.RecordObjects(targets, "Reset Position");
            foreach (Transform t in targets)
            {
                t.localPosition = Vector3.zero;
            }
            serializedObject.Update();
        }
        EditorGUILayout.PropertyField(mPos, new GUIContent("Position"));
        GUILayout.EndHorizontal();
    }

    void DrawScale()
    {
        GUILayout.BeginHorizontal();
        if (GUILayout.Button("S", GUILayout.Width(20f)))
        {
            Undo.RecordObjects(targets, "Reset Scale");
            foreach (Transform t in targets)
            {
                t.localScale = Vector3.one;
            }
            serializedObject.Update();
        }
        EditorGUILayout.PropertyField(mScale, new GUIContent("Scale"));
        GUILayout.EndHorizontal();
    }

    void DrawRotation()
    {
        GUILayout.BeginHorizontal();
        if (GUILayout.Button("R", GUILayout.Width(20f)))
        {
            Undo.RecordObjects(targets, "Reset Rotation");
            foreach (Transform t in targets)
            {
                t.localRotation = Quaternion.identity;
            }
            serializedObject.Update();
        }

        EditorGUI.BeginChangeCheck();
        Vector3 currentEuler = TransformUtils.GetInspectorRotation((Transform)target);
        Vector3 newEuler = EditorGUILayout.Vector3Field(new GUIContent("Rotation"), currentEuler);

        if (EditorGUI.EndChangeCheck())
        {
            Undo.RecordObjects(targets, "Change Rotation");
            foreach (Transform t in targets)
            {
                TransformUtils.SetInspectorRotation(t, newEuler);
            }
            serializedObject.Update();
        }
        GUILayout.EndHorizontal();
    }
}
